PORT=

POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
REDIS_HOST=
REDIS_PORT=
JWT_SECRET=

# Shared secret for backend-authority endpoints (e.g. POST /proposition/:id/settle).
# Sent as the x-server-secret header. See src/auth/server-secret.guard.ts.
SERVER_SECRET=

# Solana / on-chain program (swipe_n_rekt, native SOL — see src/solana/).
# RPC/program id default to devnet if unset; the keeper secret key is
# required for market creation (initializeMarket) and settlement
# (settleMarketMock) — leave unset to run read-only.
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=iZvZwSKPvRZpEqxyXSiRGos9pGuuzygmKdcAB6biffQ
SOLANA_KEEPER_SECRET_KEY=

# Optional: TxLine integration (see src/match/txline.service.ts). Leave unset
# until an API token has been activated via TxLine's on-chain subscribe flow.
TXLINE_API_BASE_URL=
TXLINE_API_TOKEN=

# Optional: TxLine fixtures sync (see src/match/match.schedule.ts). Get
# TXLINE_TOKEN and TXLINE_JWT via scripts/txline-test.ts's activation flow.
# TXLINE_COMPETITION_ID filters to one competition; leave unset to sync all.
TXLINE_TOKEN=
TXLINE_JWT=
TXLINE_COMPETITION_ID=
